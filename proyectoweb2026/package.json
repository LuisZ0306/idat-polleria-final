{
  "name": "proyectoweb2026",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "bootstrap": "^5.3.8",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "backend": "json-server --watch db.json --port 4000",
    "backup": "powershell -Command \"$db = Get-Content db.json | ConvertFrom-Json; $db.usuarios | ConvertTo-Json | Set-Content src/Data/usuarios.json; $db.clientes | ConvertTo-Json | Set-Content src/Data/usuarios.json -Append; $db.reservas | ConvertTo-Json | Set-Content src/Data/reservas.json; $db.pedidos | ConvertTo-Json | Set-Content src/Data/menu.json\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "json-server": "^1.0.0-beta.12"
  }
}
